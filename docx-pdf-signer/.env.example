# URLs internas (rede docker)
GOTENBERG_URL=http://gotenberg:3000
SIGNER_URL=http://signer:8000

# Timeouts (ms)
GOTENBERG_TIMEOUT_MS=120000
SIGNER_TIMEOUT_MS=60000

# Limite de upload (MB)
MAX_UPLOAD_MB=25

# TSA padrao para carimbo de tempo RFC 3161 (opcional).
# Use uma TSA ICP-Brasil ou compativel. Em branco => assinatura PAdES B-B (sem carimbo).
DEFAULT_TSA_URL=
